# Analytics (self-hosted Umami — same pattern as antonyaddy.com)
# Leave unset to keep analytics inert (no script is injected).
VITE_UMAMI_SRC=https://your-umami-host/script.js
VITE_UMAMI_WEBSITE_ID=your-website-id

# Required for the live AI tools (/generateur-programme, /correction-email).
# Set this in Vercel project settings, NOT in a committed file.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: overrides the default model used by the two live tools.
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
